#!/bin/bash
set -e
# Debian post-install maintainer script for alou
echo "[alou] postinst: starting"

# Ensure apt-get is available and update
if command -v apt-get >/dev/null 2>&1; then
  echo "[alou] Running apt-get update..."
  apt-get update -y || true

  deps=(git curl zsh yt-dlp aria2 nmap lsd bat pv unzip p7zip-full unrar-free zenity python3 python3-gi)
  echo "[alou] Installing dependencies: ${deps[*]}"
  DEBIAN_FRONTEND=noninteractive apt-get install -y "${deps[@]}" || true
fi

# Ensure /usr/local/alou exists
mkdir -p /usr/local/alou
chown -R root:root /usr/local/alou || true
chmod -R 0755 /usr/local/alou || true

# Ensure profile.d loader is installed
if [ -d /etc/profile.d ]; then
  chmod 0755 /etc/profile.d/alou.sh || true
fi

# Ensure GUI launcher and scripts are executable
chmod +x /usr/local/bin/alou-gui || true
chmod +x /usr/local/bin/alou || true
if [ -d /usr/local/alou ]; then
  find /usr/local/alou -type f -name "*.sh" -exec chmod +x {} \; || true
  find /usr/local/alou -type f -name "*.py" -exec chmod +x {} \; || true
fi

echo "[alou] Configuring zsh: installing chsh and set zsh as login shell if requested"
# Do not force-change user's shell. Just ensure zsh is available.

cat <<'EOF'
✅ Alou installed. Open a NEW terminal to activate aliases and functions.
If some commands are missing, try: sudo apt-get install <package>
EOF

exit 0